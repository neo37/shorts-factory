[Unit]
Description=VideoBot web (Flask admin + external API)
After=network.target redis-server.service

[Service]
Type=simple
User=n36
WorkingDirectory=/home/n36/VIDEO/OpenMontage/videobot
EnvironmentFile=/home/n36/VIDEO/OpenMontage/videobot/.env
ExecStart=/home/n36/VIDEO/OpenMontage/videobot/.venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 --timeout 120 wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
