# ---- Flask ----
SECRET_KEY=change-me-please
ADMIN_USER=admin
ADMIN_PASSWORD=strong-password-here
DATA_DIR=/home/n36/VIDEO/OpenMontage/videobot/data

# ---- Billing ----
NEW_USER_CREDITS=100
CREDITS_PER_VIDEO=1
TOPUP_RUB=500
TOPUP_VIDEOS=5

# ---- Branding / links ----
PROJECT_FOOTER_URL=https://videos.ai3d.art
TOPUP_CONTACT_URL=https://t.me/kiselev_vasilli_andreevichd

# ---- Web upload (media larger than Telegram's ~20 MB bot limit) ----
PUBLIC_BASE_URL=https://videos.ai3d.art
MAX_WEB_UPLOAD_MB=500
UPLOAD_TOKEN_TTL_HOURS=24

# ---- Celery / Redis ----
REDIS_URL=redis://localhost:6379/0
# For local dev without Redis set this to 1 (runs tasks inline):
CELERY_TASK_ALWAYS_EAGER=0

# ---- LLM (Ollama, OpenAI-compatible) ----
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:3b-instruct
LLM_TIMEOUT=120

# ---- TTS ----
TTS_BACKEND=auto
KOKORO_BASE_URL=http://localhost:8880/v1
PIPER_BIN=piper
PIPER_VOICE_FEMALE=ru_RU-irina-medium
PIPER_VOICE_MALE=ru_RU-ruslan-medium
# Optional fallback:
OPENAI_API_KEY=

# ---- ASR (voice-message prompts) ----
ASR_BASE_URL=http://localhost:8890/v1
ASR_MODEL=nvidia/nemotron-3.5-asr-streaming-0.6b
ASR_TIMEOUT=120

# ---- OpenMontage ----
OPENMONTAGE_DIR=/home/n36/VIDEO/OpenMontage
RENDER_QUALITY=high
RENDER_FPS=30
